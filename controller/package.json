{
  "name": "@etauker-projects/home-automation-controller",
  "version": "0.1.0",
  "description": "App for controlling home automation.",
  "keywords": [
    "home-automation"
  ],
  "license": "ISC",
  "author": "etauker",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx --watch --env-file .env src/index.ts",
    "start": "node--env-file .env dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest",
    "test:run": "vitest --run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tsconfig/node24": "^24.0.3",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.13",
    "@vitest/eslint-plugin": "^1.4.3",
    "eslint": "^9.39.1",
    "eslint-plugin-perfectionist": "^4.15.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.47.0",
    "vitest": "^4.0.17"
  },
  "imports": {
    "#*": "./src/*"
  }
}
