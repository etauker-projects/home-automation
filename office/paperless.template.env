# See http://docs.paperless-ngx.com/configuration/ for all available options.

# Needed for write access to the consumption directory.
USERMAP_UID=
USERMAP_GID=

# Proxy config
PAPERLESS_URL=
PAPERLESS_ALLOWED_HOSTS=
PAPERLESS_CSRF_TRUSTED_ORIGINS=
PAPERLESS_USE_X_FORWARD_HOST=
PAPERLESS_USE_X_FORWARD_PORT=
PAPERLESS_USE_X_FORWARD_PROTO=

# Adjust this key if you plan to make paperless available publicly. It should
# be a very long sequence of random characters. You don't need to remember it.
#PAPERLESS_SECRET_KEY=

# Use this variable to set a timezone for the Paperless Docker containers. Defaults to UTC.
PAPERLESS_TIME_ZONE=

# The default language to use for OCR. Set this to the language most of your
# documents are written in.
PAPERLESS_OCR_LANGUAGE=

# Additional languages to install for text recognition, separated by a whitespace.
# Note that this is different from PAPERLESS_OCR_LANGUAGE (default=
# the language used for OCR.
# The container installs English, German, Italian, Spanish and French by default.
# See https://packages.debian.org/search?keywords=tesseract-ocr-&searchon=names
# for available languages.
#PAPERLESS_OCR_LANGUAGES=